<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="30" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cropsentinel.StatsController"
      style="-fx-padding: 30; -fx-background-color: #f5f5f5;">

    <Label text="Dashboard Overview"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>

    <HBox spacing="20">
        <VBox style="-fx-background-color: #2d5a27; -fx-padding: 20; -fx-pref-width: 180; -fx-background-radius: 8;">
            <Label text="Total Forecasts" style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Label fx:id="totalLabel" text="..." style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #e67e22; -fx-padding: 20; -fx-pref-width: 180; -fx-background-radius: 8;">
            <Label text="Average Risk" style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Label fx:id="avgRiskLabel" text="..." style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>
        <VBox style="-fx-background-color: #c0392b; -fx-padding: 20; -fx-pref-width: 180; -fx-background-radius: 8;">
            <Label text="Highest Risk" style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Label fx:id="highestRiskLabel" text="..." style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #ddd;">
        <Label text="Most Common Disease" style="-fx-font-size: 13; -fx-text-fill: gray;"/>
        <Label fx:id="diseaseLabel" text="..." style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>
    </VBox>

</VBox>