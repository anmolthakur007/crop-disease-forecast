<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cropsentinel.HistoryController"
      style="-fx-padding: 30; -fx-background-color: #f5f5f5;">

    <Label text="Forecast History"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>

    <Button text="🔄  Refresh" onAction="#loadHistory"
            style="-fx-background-color: #2d5a27; -fx-text-fill: white; -fx-padding: 8 16;"/>

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="conditionCol" text="Condition" prefWidth="220"/>
            <TableColumn fx:id="riskCol" text="Risk %" prefWidth="100"/>
            <TableColumn fx:id="confidenceCol" text="Confidence %" prefWidth="120"/>
            <TableColumn fx:id="tempCol" text="Temp °C" prefWidth="90"/>
            <TableColumn fx:id="humidityCol" text="Humidity %" prefWidth="110"/>
            <TableColumn fx:id="dateCol" text="Date/Time" prefWidth="180"/>
        </columns>
    </TableView>

</VBox>