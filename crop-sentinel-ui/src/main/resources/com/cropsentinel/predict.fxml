<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cropsentinel.PredictController"
      style="-fx-padding: 30; -fx-background-color: #f5f5f5;">

    <Label text="Upload Leaf Image &amp; Get Forecast"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>

    <HBox spacing="20">
        <VBox spacing="10">
            <Label text="Latitude:"/>
            <TextField fx:id="latField" promptText="e.g. 18.5204" prefWidth="200"/>
            <Label text="Longitude:"/>
            <TextField fx:id="lonField" promptText="e.g. 73.8567" prefWidth="200"/>
            <Button text="📁  Choose Leaf Image" onAction="#chooseImage"
                    style="-fx-background-color: #2d5a27; -fx-text-fill: white; -fx-padding: 10 20;"/>
            <Label fx:id="fileLabel" text="No file chosen" style="-fx-text-fill: gray;"/>
            <Button text="🔍  Get Forecast" onAction="#getForecast"
                    style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-size: 14;"/>
        </VBox>

        <VBox fx:id="resultBox" spacing="15" style="-fx-padding: 20; -fx-background-color: white;
              -fx-border-color: #ddd; -fx-border-radius: 8;" visible="false">
            <Label text="Results" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label fx:id="riskLabel" text="" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label fx:id="conditionLabel" text=""/>
            <Label fx:id="tempLabel" text=""/>
            <Label fx:id="humidityLabel" text=""/>
            <Label fx:id="confidenceLabel" text=""/>
        </VBox>
    </HBox>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: gray;"/>

</VBox>