<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cropsentinel.ChartController"
      style="-fx-padding: 30; -fx-background-color: #f5f5f5;">

    <Label text="Risk Score Chart"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2d5a27;"/>

    <Button text="🔄  Refresh" onAction="#loadChart"
            style="-fx-background-color: #2d5a27; -fx-text-fill: white; -fx-padding: 8 16;"/>

    <BarChart fx:id="riskChart" VBox.vgrow="ALWAYS">
        <xAxis>
            <CategoryAxis label="Forecast"/>
        </xAxis>
        <yAxis>
            <NumberAxis label="Risk %" lowerBound="0" upperBound="100"/>
        </yAxis>
    </BarChart>

</VBox>