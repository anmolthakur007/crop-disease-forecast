<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cropsentinel.MainController"
            prefWidth="900" prefHeight="600">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #2d5a27; -fx-padding: 20;">
            <Label text="🌱 Crop Sentinel" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Separator/>
            <Button fx:id="btnPredict" text="📷  Predict" onAction="#showPredict"
                    maxWidth="Infinity" style="-fx-background-color: #4a7c59; -fx-text-fill: white;"/>
            <Button fx:id="btnHistory" text="📋  History" onAction="#showHistory"
                    maxWidth="Infinity" style="-fx-background-color: #4a7c59; -fx-text-fill: white;"/>
            <Button fx:id="btnChart" text="📊  Chart" onAction="#showChart"
                    maxWidth="Infinity" style="-fx-background-color: #4a7c59; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>